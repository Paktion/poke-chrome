{
  "manifest_version": 3,
  "name": "Pokemon Cursor",
  "version": "1.1.0",
  "description": "A Pokemon follows your cursor on every page. Pick from Ditto, Infernape, Lucario, Shiftree, or Mewtwo.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Pokemon Cursor",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "permissions": ["storage"],
  "background": {
    "service_worker": "background.js"
  },
  "commands": {
    "toggle-cursor": {
      "suggested_key": {
        "default": "Ctrl+Shift+0"
      },
      "description": "Toggle Pokemon Cursor on/off"
    }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "ditto.png",
        "infernape.png",
        "lucario.png",
        "shiftree.png",
        "mewtwo.png"
      ],
      "matches": ["<all_urls>"]
    }
  ]
}
